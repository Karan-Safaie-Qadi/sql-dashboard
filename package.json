{
  "name": "sql-dashboard",
  "version": "1.0.1",
  "description": "🚀 Professional SQL management dashboard for admin panels - Execute queries, browse schemas, manage databases with ease",
  "keywords": [
    "sql",
    "database",
    "admin",
    "dashboard",
    "query",
    "mysql",
    "postgresql",
    "sqlite",
    "mssql",
    "admin-panel",
    "database-manager",
    "sql-editor"
  ],
  "homepage": "https://github.com/Karan-Safaie-Qadi/sql-dashboard",
  "bugs": {
    "url": "https://github.com/Karan-Safaie-Qadi/sql-dashboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Karan-Safaie-Qadi/sql-dashboard.git"
  },
  "license": "MIT",
  "author": {
    "name": "Karan Safaie Qadi",
    "url": "https://github.com/Karan-Safaie-Qadi"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.mjs",
      "require": "./dist/middleware/express.js"
    },
    "./fastify": {
      "types": "./dist/middleware/fastify.d.ts",
      "import": "./dist/middleware/fastify.mjs",
      "require": "./dist/middleware/fastify.js"
    },
    "./drivers/*": {
      "types": "./dist/drivers/*.d.ts",
      "import": "./dist/drivers/*.mjs",
      "require": "./dist/drivers/*.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export/index.mjs",
      "require": "./dist/export/index.js"
    },
    "./demo": {
      "types": "./dist/demo/index.d.ts",
      "import": "./dist/demo/index.mjs",
      "require": "./dist/demo/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --splitting --out-dir dist",
    "build:all": "npm run build && npm run build:subpaths",
    "build:subpaths": "tsup src/middleware/express.ts src/middleware/fastify.ts src/export/index.ts src/drivers/mysql.driver.ts src/drivers/postgres.driver.ts src/drivers/mssql.driver.ts src/demo/index.ts --format cjs,esm --dts --out-dir dist",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:all",
    "prepare": "npm run build:all",
    "docs": "typedoc --out docs src/index.ts",
    "example:basic": "tsx examples/basic.ts",
    "example:express": "tsx examples/express.ts",
    "example:admin": "tsx examples/admin-panel.ts",
    "demo": "tsx src/demo/index.ts",
    "release": "npm run build:all && npm run test && npm run lint",
    "release:publish": "npm run build:all && npm test && npm publish --access public && powershell -Command \"$ver = node -p \\\"require('./package.json').version\\\"; gh release create v$ver --title v$ver --notes \\\"See CHANGELOG.md for details\\\" --generate-notes\""
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "mysql2": "^3.9.0",
    "pg": "^8.11.0",
    "tedious": "^18.0.0"
  },
  "peerDependencies": {
    "express": "^4.18.0",
    "fastify": "^4.26.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "express": "^4.18.0",
    "fastify": "^4.26.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
