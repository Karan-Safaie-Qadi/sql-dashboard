# SQL-Dashboard Configuration
# Copy this file to .env and adjust values

# Database type: sqlite | mysql | postgres | mssql
DB_TYPE=sqlite

# SQLite options
DB_MODE=memory
DB_PATH=./dashboard.db

# MySQL / Postgres / MSSQL options
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=test
DB_SCHEMA=public

# Server
PORT=3000
LOG_LEVEL=silent
CORS_ORIGIN=http://localhost:5173
